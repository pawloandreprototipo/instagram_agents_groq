# Copie este arquivo para .env e preencha com suas credenciais reais
# cp .env.example .env

# Chave da API Groq — obtenha em https://console.groq.com
GROQ_API_KEY=sua_chave_groq_aqui

# Chave da API OpenAI — obtenha em https://platform.openai.com (opcional)
# OPENAI_API_KEY=sua_chave_openai_aqui

# Conta Instagram usada para autenticação via API privada
INSTAGRAM_USERNAME=seu_usuario_instagram
INSTAGRAM_PASSWORD=sua_senha_instagram

# Diretório de saída (opcional, padrão: output)
OUTPUT_DIR=output

# Nível de log (opcional, padrão: INFO)
# Opções: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Provider e modelo por agent (opcional — padrão: groq)
# Provedores suportados: groq, openai
MEDIA_AGENT_PROVIDER=groq
MEDIA_AGENT_MODEL=llama-3.3-70b-versatile

# Exemplos para usar OpenAI em um agent específico:
# MEDIA_AGENT_PROVIDER=openai
# MEDIA_AGENT_MODEL=gpt-4o
